{
    "workspace": [
        "lint-rules",
        "packages/engine",
        "packages/game",
        "packages/platform-browser",
        "packages/platform-sdl"
    ],
    "compilerOptions": {
        "lib": [
            "deno.window",
            "dom",
            "dom.iterable",
            "dom.asynciterable",
            "esnext"
        ],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "lint": {
        "plugins": [
            "./lint-rules/sidebound-lint-plugin.ts"
        ],
        "rules": {
            "tags": [
                "recommended"
            ]
        },
        "exclude": [
            "packages/game/dist"
        ]
    },
    "fmt": {
        "include": [
            "deno.json",
            "lint-rules/**/*.ts",
            "packages/engine/**/*.ts",
            "packages/game/**/*.ts",
            "packages/platform-browser/**/*.ts",
            "packages/platform-sdl/**/*.ts"
        ],
        "exclude": [
            "packages/game/dist"
        ],
        "indentWidth": 4,
        "lineWidth": 180,
        "semiColons": false,
        "singleQuote": true
    },
    "tasks": {
        "dev": "deno task --cwd packages/game dev",
        "build": "deno task --cwd packages/game build",
        "preview": "deno task --cwd packages/game preview",
        "typecheck": "deno check packages/engine/**/*.ts packages/platform-browser/**/*.ts packages/game/**/*.ts packages/game/tools/build_browser_preview.ts packages/game/tools/serve_browser_preview.ts",
        "lint": "deno lint packages/engine/src packages/platform-browser/src packages/game/src packages/game/tools",
        "check": "deno task typecheck && deno task lint",
        "format": "deno fmt"
    }
}
