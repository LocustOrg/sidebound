        "build": "deno check src/main.ts vite.config.ts && deno run --node-modules-dir=auto --allow-env --allow-read --allow-write --allow-net --allow-sys --allow-ffi npm:vite@8.0.14 build .",
        "preview": "deno run --node-modules-dir=auto --allow-env --allow-read --allow-net --allow-sys --allow-ffi npm:vite@8.0.14 preview --host 0.0.0.0 .",
